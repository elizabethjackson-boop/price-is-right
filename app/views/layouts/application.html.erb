<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Price Is Right" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="min-height:100vh; background:linear-gradient(135deg,#1e3a5f 0%,#2a4a6b 50%,#1e3a5f 100%); color:#f1f5f9; font-family:system-ui,-apple-system,sans-serif; margin:0; padding:0;">
    <%= yield %>
  </body>
</html>
