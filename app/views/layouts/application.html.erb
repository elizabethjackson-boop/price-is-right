<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Price Is Right" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Animated marquee light bar at top -->
    <div class="marquee-bar" style="position:fixed; top:0; left:0; right:0; z-index:200;"></div>

    <%= yield %>

    <!-- Animated marquee light bar at bottom -->
    <div class="marquee-bar" style="position:fixed; bottom:0; left:0; right:0; z-index:200;"></div>
  </body>
</html>
