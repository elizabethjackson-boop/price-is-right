<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Price Is Right" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Animated marquee light bar at top -->
    <div class="marquee-bar" style="position:fixed; top:0; left:0; right:0; z-index:200;"></div>

    <%= yield %>

    <!-- Animated marquee light bar at bottom -->
    <div class="marquee-bar" style="position:fixed; bottom:0; left:0; right:0; z-index:200;"></div>

    <!-- Generate light bulb dots around .bulb-border elements -->
    <script>
      document.addEventListener("turbo:load", initBulbs);
      document.addEventListener("DOMContentLoaded", initBulbs);
      function initBulbs() {
        var colors = ['#FFD700','#FF3333','#00E676','#FF8C00'];
        var CYCLE = 6; // seconds for one full loop around the border
        var SPACING = 36;

        document.querySelectorAll('.bulb-border').forEach(function(el) {
          if (el.dataset.bulbsInit) return;
          el.dataset.bulbsInit = '1';
          var w = el.offsetWidth, h = el.offsetHeight;

          // Build bulb positions CLOCKWISE around the perimeter:
          // Top (left→right), Right (top→bottom), Bottom (right→left), Left (bottom→top)
          var bulbs = [];
          // Top edge
          for (var x = SPACING/2; x < w; x += SPACING)
            bulbs.push({ left: x - 6, top: -6 });
          // Right edge
          for (var y = SPACING/2; y < h; y += SPACING)
            bulbs.push({ left: w - 6, top: y - 6 });
          // Bottom edge (right to left)
          for (var x = w - SPACING/2; x > 0; x -= SPACING)
            bulbs.push({ left: x - 6, top: h - 6 });
          // Left edge (bottom to top)
          for (var y = h - SPACING/2; y > 0; y -= SPACING)
            bulbs.push({ left: -6, top: y - 6 });

          var total = bulbs.length;
          bulbs.forEach(function(pos, i) {
            var dot = document.createElement('div');
            dot.className = 'bulb-dot';
            dot.style.left = pos.left + 'px';
            dot.style.top = pos.top + 'px';
            dot.style.setProperty('--bulb-color', colors[i % colors.length]);
            // Stagger delays so the light wave travels around the border
            dot.style.setProperty('--bulb-cycle', CYCLE + 's');
            dot.style.setProperty('--bulb-delay', ((i / total) * CYCLE).toFixed(2) + 's');
            el.appendChild(dot);
          });
        });
      }
    </script>
  </body>
</html>
