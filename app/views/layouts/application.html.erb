<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Price Is Right" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Animated marquee light bar at top -->
    <div class="marquee-bar" style="position:fixed; top:0; left:0; right:0; z-index:200;"></div>

    <%= yield %>

    <!-- Animated marquee light bar at bottom -->
    <div class="marquee-bar" style="position:fixed; bottom:0; left:0; right:0; z-index:200;"></div>

    <!-- Persistent background music — lives in layout so it survives Turbo navigations -->
    <script>
      // Create the audio element ONCE on the window and reuse it forever.
      // Turbo replaces the <body> contents but this script re-attaches the
      // existing audio element each time, so the song never restarts.
      (function() {
        if (!window._bgmAudio) {
          var a = new Audio('https://assets.mixkit.co/music/787/787.mp3');
          a.loop = true;
          a.volume = 0.35;
          a.preload = 'auto';
          window._bgmAudio = a;
          window._bgmMuted = false;
          window._bgmInteracted = false;
        }

        function tryPlay() {
          if (window._bgmMuted) return;
          window._bgmAudio.play().catch(function(){});
        }

        // First-interaction auto-start (browser autoplay policy)
        function onFirstInteraction() {
          if (window._bgmInteracted) return;
          window._bgmInteracted = true;
          tryPlay();
        }

        // Re-bind listeners on every Turbo page load
        function bindInteraction() {
          if (!window._bgmInteracted) {
            document.addEventListener('click', onFirstInteraction, { once: true, capture: true });
            document.addEventListener('keydown', onFirstInteraction, { once: true, capture: true });
          } else {
            // Already interacted — make sure it's still playing (Turbo nav)
            tryPlay();
          }
        }

        // Update the mute button UI if it exists on the current page
        function updateMusicBtn() {
          var btn = document.getElementById('music-toggle');
          var icon = document.getElementById('music-icon');
          if (!btn || !icon) return;
          if (window._bgmMuted || window._bgmAudio.paused) {
            icon.innerHTML = '\u{1F509}';
            btn.classList.remove('music-playing');
          } else {
            icon.innerHTML = '\u{1F50A}';
            btn.classList.add('music-playing');
          }
        }

        // Expose helpers for the mute button in host.html.erb
        window._bgmToggle = function() {
          if (window._bgmMuted || window._bgmAudio.paused) {
            window._bgmMuted = false;
            window._bgmAudio.play().catch(function(){});
          } else {
            window._bgmMuted = true;
            window._bgmAudio.pause();
          }
          updateMusicBtn();
        };

        // Run on every Turbo navigation + initial load
        document.addEventListener('turbo:load', function() { bindInteraction(); setTimeout(updateMusicBtn, 50); });
        document.addEventListener('DOMContentLoaded', function() { bindInteraction(); setTimeout(updateMusicBtn, 50); });
        // Also run immediately in case this script fires after DOMContentLoaded
        bindInteraction();
      })();
    </script>

    <!-- Generate light bulb dots around .bulb-border elements -->
    <script>
      document.addEventListener("turbo:load", initBulbs);
      document.addEventListener("DOMContentLoaded", initBulbs);
      function initBulbs() {
        var colors = ['#FFD700','#FFAA00','#FFE066','#FF8C00','#FFC844','#FFB733'];
        var CYCLE = 6; // seconds for one full loop around the border
        var SPACING = 36;

        document.querySelectorAll('.bulb-border').forEach(function(el) {
          if (el.dataset.bulbsInit) return;
          el.dataset.bulbsInit = '1';
          var w = el.offsetWidth, h = el.offsetHeight;

          // Build bulb positions CLOCKWISE around the perimeter:
          // Top (left→right), Right (top→bottom), Bottom (right→left), Left (bottom→top)
          var bulbs = [];
          // Top edge
          for (var x = SPACING/2; x < w; x += SPACING)
            bulbs.push({ left: x - 6, top: -6 });
          // Right edge
          for (var y = SPACING/2; y < h; y += SPACING)
            bulbs.push({ left: w - 6, top: y - 6 });
          // Bottom edge (right to left)
          for (var x = w - SPACING/2; x > 0; x -= SPACING)
            bulbs.push({ left: x - 6, top: h - 6 });
          // Left edge (bottom to top)
          for (var y = h - SPACING/2; y > 0; y -= SPACING)
            bulbs.push({ left: -6, top: y - 6 });

          var total = bulbs.length;
          bulbs.forEach(function(pos, i) {
            var dot = document.createElement('div');
            dot.className = 'bulb-dot';
            dot.style.left = pos.left + 'px';
            dot.style.top = pos.top + 'px';
            dot.style.setProperty('--bulb-color', colors[i % colors.length]);
            // Stagger delays so the light wave travels around the border
            dot.style.setProperty('--bulb-cycle', CYCLE + 's');
            dot.style.setProperty('--bulb-delay', ((i / total) * CYCLE).toFixed(2) + 's');
            el.appendChild(dot);
          });
        });
      }
    </script>
  </body>
</html>
