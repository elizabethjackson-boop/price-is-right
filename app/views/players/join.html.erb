<% content_for :title, "The Price Is Right — Join!" %>

<div style="display:flex; flex-direction:column; align-items:center; padding:20px 16px; min-height:100vh;">
  <div style="text-align:center; margin:60px 0 40px">
    <div style="font-size:13px; letter-spacing:4px; color:#f59e0b; font-weight:600; margin-bottom:12px">CLEVER REAL ESTATE PRESENTS</div>
    <h1 style="font-size:40px; font-weight:800; line-height:1.1; color:white">THE PRICE IS RIGHT</h1>
    <p style="font-size:18px; color:rgba(255,255,255,0.5); margin-top:8px">Real Estate Edition</p>
  </div>

  <div style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); border-radius:16px; padding:28px; max-width:500px; width:100%; text-align:center;">
    <h2 style="font-size:20px; margin-bottom:20px; color:rgba(255,255,255,0.9)">What's your name?</h2>

    <% if @player&.errors&.any? %>
      <div style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); border-radius:8px; padding:12px; margin-bottom:16px; color:#ef4444;">
        <%= @player.errors.full_messages.first %>
      </div>
    <% end %>

    <%= form_with url: "/play/#{@game.code}", method: :post do |f| %>
      <%= f.text_field :name,
          placeholder: "Type your name",
          autofocus: true,
          style: "background:rgba(255,255,255,0.1); border:2px solid rgba(255,255,255,0.2); border-radius:12px; padding:16px 20px; color:white; font-size:20px; font-weight:600; width:100%; outline:none; box-sizing:border-box; text-align:center; margin-bottom:20px;",
          data: { action: "keydown.enter->form#submit" } %>
      <%= f.submit "I'M READY",
          style: "background:#f59e0b; color:#1e3a5f; border:none; border-radius:12px; padding:16px 32px; font-size:18px; font-weight:700; cursor:pointer; width:100%; letter-spacing:0.5px;" %>
    <% end %>
  </div>

  <p style="color:rgba(255,255,255,0.3); font-size:13px; margin-top:24px; text-align:center">
    Look at the host's screen to see each house. Type your guess here.
  </p>
</div>
