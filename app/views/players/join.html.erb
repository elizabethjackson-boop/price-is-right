<% content_for :title, "The Price Is Right — Join!" %>

<div style="display:flex; flex-direction:column; align-items:center; padding:20px 16px; min-height:100vh;">
  <div style="text-align:center; margin:60px 0 32px" class="slide-up">
    <div style="font-size:13px; letter-spacing:4px; color:var(--pir-gold); font-weight:600; margin-bottom:12px">&#9733; CLEVER REAL ESTATE PRESENTS &#9733;</div>
    <h1 class="show-title neon-text" style="font-size:40px; font-weight:800; line-height:1.1; color:white">THE PRICE IS RIGHT</h1>
    <p style="font-size:18px; color:rgba(255,255,255,0.5); margin-top:8px; font-weight:600;">Real Estate Edition &#127968;</p>
    <div class="marquee-bar" style="width:200px; margin:16px auto 0;"></div>
  </div>

  <div class="bulb-border slide-up" style="max-width:500px; width:100%; animation-delay:0.2s;">
    <div class="pir-card" style="text-align:center;">
      <div style="font-size:48px; margin-bottom:12px;">&#127918;</div>
      <h2 style="font-size:22px; margin-bottom:20px; color:white; font-weight:700;">What's your name?</h2>

      <% if @player&.errors&.any? %>
        <div style="background:rgba(255,51,51,0.1); border:1px solid rgba(255,51,51,0.3); border-radius:12px; padding:12px; margin-bottom:16px; color:var(--pir-red);">
          <%= @player.errors.full_messages.first %>
        </div>
      <% end %>

      <%= form_with url: "/play/#{@game.code}", method: :post do |f| %>
        <%= f.text_field :name,
            placeholder: "Type your name",
            autofocus: true,
            class: "pir-input",
            style: "font-size:22px; margin-bottom:20px;",
            data: { action: "keydown.enter->form#submit" } %>
        <%= f.submit "I'M READY!", class: "pir-btn" %>
      <% end %>
    </div>
  </div>

  <p style="color:rgba(255,255,255,0.3); font-size:13px; margin-top:24px; text-align:center">
    Look at the host's screen to see each house. Type your guess here.
  </p>
</div>
