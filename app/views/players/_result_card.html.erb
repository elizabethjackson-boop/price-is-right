<% over = guess.result == "lose" %>
<% exact = guess.result == "exact" %>
<% icon = exact ? "&#127919;" : over ? "&#128200;" : "&#9989;" %>
<% label = exact ? "EXACT MATCH!" : over ? "OVER" : "UNDER" %>
<% label_color = exact ? "#f59e0b" : over ? "#ef4444" : "#10b981" %>
<% diff_text = exact ? "Nailed it!" : "$#{number_with_delimiter(guess.diff.abs)}#{over ? ' too high' : ' under'}" %>
<% card_style = over ? "background:rgba(239,68,68,0.1); border:2px solid rgba(239,68,68,0.3);" : "background:rgba(16,185,129,0.15); border:2px solid rgba(16,185,129,0.4);" %>

<div style="<%= card_style %> border-radius:12px; padding:20px; text-align:center; margin-top:16px;">
  <div style="font-size:36px; margin-bottom:8px;"><%= icon.html_safe %></div>
  <div style="font-size:13px; letter-spacing:2px; font-weight:700; color:<%= label_color %>; margin-bottom:8px;"><%= label %></div>
  <div style="font-size:15px; color:rgba(255,255,255,0.5); margin-bottom:4px;">Your guess</div>
  <div style="font-size:28px; font-weight:700; margin-bottom:12px;">$<%= number_with_delimiter(guess.amount) %></div>
  <div style="font-size:16px; color:rgba(255,255,255,0.6);"><%= diff_text %></div>
</div>
