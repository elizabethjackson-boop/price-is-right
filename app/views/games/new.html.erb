<% content_for :title, "The Price Is Right — Host Setup" %>

<div style="display:flex; flex-direction:column; align-items:center; padding:40px 16px; min-height:100vh;">

  <%# ── Show Logo / Title ── %>
  <div style="text-align:center; margin:60px 0 40px" class="slide-up">
    <div style="font-size:14px; letter-spacing:4px; color:var(--pir-gold); font-weight:600; margin-bottom:12px">&#9733; CLEVER REAL ESTATE PRESENTS &#9733;</div>
    <h1 class="show-title neon-text" style="font-size:56px; font-weight:800; line-height:1.1; color:white">THE PRICE IS RIGHT</h1>
    <p style="font-size:24px; color:rgba(255,255,255,0.5); margin-top:10px; font-weight:600;">Real Estate Edition &#127968;</p>
    <div class="marquee-bar" style="width:300px; margin:20px auto 0;"></div>
  </div>

  <%# ── Create Game Card ── %>
  <div class="bulb-border slide-up" style="max-width:600px; width:100%; animation-delay:0.2s;">
    <div class="pir-card" style="text-align:center;">
      <div style="font-size:48px; margin-bottom:12px;">&#127922;</div>
      <h2 style="font-size:24px; margin-bottom:8px; color:white; font-weight:700;">Ready to host a game?</h2>
      <p style="font-size:16px; color:rgba(255,255,255,0.5); margin-bottom:28px;">5 listings. Guess the price. Closest without going over wins.</p>

      <%= form_with url: games_path, method: :post do |f| %>
        <%= f.submit "CREATE GAME", class: "pir-btn" %>
      <% end %>
    </div>
  </div>

  <p style="color:rgba(255,255,255,0.3); font-size:13px; margin-top:24px; text-align:center">
    A join code will be generated for players to enter on their devices.
  </p>
</div>
