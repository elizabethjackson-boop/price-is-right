<% if players.any? %>
  <div style="margin-bottom:12px;">
    <div class="sub-label" style="margin-bottom:12px">&#127881; <%= players.count %> PLAYER<%= players.count != 1 ? "S" : "" %> JOINED</div>
    <div style="display:flex; flex-wrap:wrap; gap:8px; justify-content:center;">
      <% players.each do |player| %>
        <div class="player-pill"><%= player.name %></div>
      <% end %>
    </div>
  </div>
<% else %>
  <p style="font-size:15px; color:rgba(255,255,255,0.35); margin-bottom:12px;">Waiting for players to join... &#128064;</p>
<% end %>
