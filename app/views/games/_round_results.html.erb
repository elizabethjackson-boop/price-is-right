<% if round_results.any? %>
  <div style="background:rgba(0,0,0,0.2); border-radius:14px; padding:18px; margin-top:12px; border:1px solid rgba(255,215,0,0.1);">
    <div class="sub-label" style="margin-bottom:14px">&#127919; THIS ROUND'S RESULTS</div>
    <% round_results.each_with_index do |guess, i| %>
      <div style="display:flex; align-items:center; gap:10px; padding:7px 0; border-bottom:1px solid rgba(255,215,0,0.05);">
        <div style="font-size:18px; width:24px; text-align:center;">
          <% if guess.correct? %>
            <% if i == 0 %>
              &#128081;
            <% elsif guess.speed_bonus > 0 %>
              &#9889;
            <% else %>
              &#9989;
            <% end %>
          <% else %>
            &#10060;
          <% end %>
        </div>
        <div style="flex:1; font-size:15px; font-weight:600; color:<%= guess.correct? ? 'rgba(255,255,255,0.85)' : 'rgba(255,255,255,0.4)' %>;">
          <%= guess.player.name %>
          <% if guess.speed_bonus > 0 %>
            <span style="font-size:11px; color:var(--pir-gold); margin-left:4px; font-weight:700;">&#9889; +<%= number_with_delimiter(guess.speed_bonus) %></span>
          <% end %>
        </div>
        <div style="text-align:right;">
          <div style="font-size:14px; font-weight:600; color:<%= guess.correct? ? 'var(--pir-green)' : 'var(--pir-red)' %>;">
            $<%= number_with_delimiter(guess.amount) %>
          </div>
          <div style="font-size:12px; font-weight:700; color:<%= guess.points > 0 ? 'var(--pir-gold)' : 'rgba(255,255,255,0.3)' %>;">
            <%= number_with_delimiter(guess.points) %> pts
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
